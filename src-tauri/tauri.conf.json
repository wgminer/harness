{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Harness",
  "version": "0.7.10",
  "identifier": "com.harness.app",
  "build": {
    "beforeDevCommand": "npm run dev:web",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build:web",
    "frontendDist": "../dist-web"
  },
  "app": {
    "windows": [
      {
        "title": "Harness",
        "width": 1024,
        "height": 768,
        "resizable": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$DATA/Harness/local-data/app-state/images/**",
          "$DATA/Harness Dev/local-data/app-state/images/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../resources/HarnessSpeech",
      "../resources/HarnessFnMonitor",
      "../resources/icon-tray.png",
      "../resources/icon-tray-recording.png",
      "../resources/icon-tray-processing.png"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0",
      "infoPlist": "Info.plist",
      "entitlements": "entitlements.plist"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/wgminer/harness/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDNCQUNBNEI0MkFDQzdGOEUKUldTT2Y4d3F0S1NzTzlSNmRCRmFtc2FucEdxbVBXQy9hNmUzVEVzUHEvbTF2b0NBTCtEV1lmUzkK"
    }
  }
}
