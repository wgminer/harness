{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Harness",
  "version": "0.7.4",
  "identifier": "com.yourcompany.harness",
  "build": {
    "beforeDevCommand": "npm run dev:web",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build:web",
    "frontendDist": "../dist-web"
  },
  "app": {
    "windows": [
      {
        "title": "Harness",
        "width": 1024,
        "height": 768,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../resources/HarnessSpeech",
      "../resources/HarnessFnMonitor",
      "../resources/icon-tray.png",
      "../resources/icon-tray-dev.png",
      "../resources/icon-tray-recording.png",
      "../resources/icon-tray-processing.png"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0",
      "infoPlist": "Info.plist"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/wgminer/harness/releases/latest/download/latest.json"
      ],
      "pubkey": ""
    }
  }
}
