# Copy to .env and fill in values. Never commit .env.

# GitHub — required for `npm run release`
GH_TOKEN=

# macOS code signing (Developer ID Application .p12)
CSC_LINK=
CSC_KEY_PASSWORD=
# CSC_NAME=Developer ID Application: Your Name (TEAM_ID)

# Apple notarization (required when REQUIRE_NOTARIZE=1 / npm run release)
APPLE_ID=
APPLE_APP_SPECIFIC_PASSWORD=
APPLE_TEAM_ID=

# Tauri updater signing — required for in-app updates
# Generate once: npx tauri signer generate -w ~/.tauri/harness.key
# Paste the printed public key into src-tauri/tauri.conf.json → plugins.updater.pubkey
TAURI_SIGNING_PRIVATE_KEY=
# TAURI_SIGNING_PRIVATE_KEY_PASSWORD=
