# Copy to `.env` and fill in values. Never commit `.env`.
# See BUILD.md for the full signing / notarization walkthrough.

# ── GitHub (required for `npm run release`) ──────────────────────────────────
GH_TOKEN=

# ── macOS code signing (required to ship to other Macs) ──────────────────────
# Local: `security find-identity -v -p codesigning`
APPLE_SIGNING_IDENTITY=Developer ID Application: Your Name (TEAM_ID)

# CI only — base64-encoded .p12 (`openssl base64 -A -in cert.p12`)
# APPLE_CERTIFICATE=
# APPLE_CERTIFICATE_PASSWORD=

# ── Apple notarization (required for Gatekeeper on other Macs) ───────────────
# APPLE_PASSWORD is an app-specific password from appleid.apple.com (not your Apple ID password).
APPLE_ID=
APPLE_PASSWORD=
APPLE_TEAM_ID=

# Alternative: App Store Connect API key (instead of APPLE_ID / APPLE_PASSWORD)
# APPLE_API_KEY=
# APPLE_API_ISSUER=
# APPLE_API_KEY_PATH=

# ── Tauri updater signing (required for in-app updates) ──────────────────────
# Generate: npx tauri signer generate -w ~/.tauri/harness.key
# Public key → src-tauri/tauri.conf.json → plugins.updater.pubkey
# Leave the password empty if the key has none (avoids a TTY prompt during dist).
TAURI_SIGNING_PRIVATE_KEY=
TAURI_SIGNING_PRIVATE_KEY_PASSWORD=


