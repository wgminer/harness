{
  "name": "harness",
  "version": "0.6.2",
  "private": true,
  "main": "out/main/index.js",
  "author": "Your Name",
  "description": "Personal all-in-one desktop harness for LLMs (chat, memory, tasks, tools)",
  "scripts": {
    "dev": "electron-vite dev",
    "prebuild": "npm run icon:icns && npm run parakeet:setup && npm run build:fn-monitor",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "dist": "node scripts/dist-runner.js",
    "dist:mac": "node scripts/dist-runner.js --mac",
    "dist:mac:replace": "node scripts/dist-runner.js --mac --replace",
    "verify:mac-trust": "node scripts/verify-mac-trust.js",
    "icon:icns": "node build/make-icns.js",
    "parakeet:setup": "node scripts/setup-parakeet.js",
    "build:fn-monitor": "bash scripts/build-fn-monitor.sh",
    "release": "node scripts/release.js",
    "site": "npx --yes serve site -l 8080",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "grid:audit": "node scripts/grid-audit.js",
    "test:all": "npm run test && npm run test:e2e",
    "test:e2e": "electron-vite build && playwright test",
    "test:e2e:ui": "electron-vite build && playwright test --ui"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "lucide-react": "^0.575.0",
    "mermaid": "^11.15.0",
    "openai": "^4.73.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-directive": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@electron/notarize": "^2.2.2",
    "@playwright/test": "^1.58.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "dotenv": "^16.6.1",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.0",
    "vitest": "^3.0.5"
  }
}
