{
  "name": "harness",
  "version": "0.7.5",
  "private": false,
  "license": "MIT",
  "author": "Will Miner",
  "description": "Personal all-in-one desktop harness for LLMs (chat, memory, tasks, tools)",
  "repository": {
    "type": "git",
    "url": "https://github.com/wgminer/harness.git"
  },
  "scripts": {
    "dev": "node scripts/make-dev-icons.js && HARNESS_DEV=1 tauri dev",
    "dev:web": "vite",
    "site": "serve site -l 8080",
    "prebuild": "npm run icon:icns && npm run build:speech-helper && npm run build:fn-monitor",
    "build": "vite build",
    "build:web": "vite build",
    "dist": "node scripts/dist-runner.js",
    "dist:quick": "node scripts/dist-runner.js --mac --quick",
    "dist:mac": "node scripts/dist-runner.js --mac",
    "dist:mac:quick": "node scripts/dist-runner.js --mac --quick",
    "dist:mac:replace": "node scripts/dist-runner.js --mac --replace",
    "verify:mac-trust": "node scripts/verify-mac-trust.js",
    "icon:icns": "node build/make-icns.js",
    "build:speech-helper": "bash scripts/build-speech-helper.sh",
    "build:fn-monitor": "bash scripts/build-fn-monitor.sh",
    "release": "node scripts/release.js",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.renderer.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "grid:audit": "node scripts/grid-audit.js"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.1",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "@tauri-apps/api": "^2.4.0",
    "@tauri-apps/plugin-dialog": "^2.2.0",
    "@tauri-apps/plugin-global-shortcut": "^2.2.0",
    "@tauri-apps/plugin-opener": "^2.2.6",
    "@tauri-apps/plugin-updater": "^2.7.0",
    "lucide-react": "^0.575.0",
    "mermaid": "^11.15.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-directive": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tauri-apps/cli": "^2.4.0",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "dotenv": "^16.6.1",
    "eslint": "^9.39.4",
    "globals": "^16.5.0",
    "serve": "^14.2.6",
    "typescript": "^5.6.3",
    "vite": "^5.4.0",
    "vitest": "^3.0.5"
  }
}
